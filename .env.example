# MongoDB
# Local: mongodb://127.0.0.1:27017/seo-dashboard
# Atlas SRV (may fail on Windows with querySrv ECONNREFUSED — use DIRECT from Atlas Connect screen):
# MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/seo-dashboard
# Atlas DIRECT (use if SRV fails — copy from Atlas → Connect → Drivers → "Standard connection string"):
# MONGODB_URI=mongodb://USER:PASS@host1:27017,host2:27017,host3:27017/seo-dashboard?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin
MONGODB_URI=mongodb://127.0.0.1:27017/seo-dashboard

# App
APP_NAME=SEO Dashboard
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
APP_KEY=base64:changeme-generate-with-openssl-rand-base64-32

# Auth
BCRYPT_ROUNDS=12
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=password

# Password reset / email verification
PASSWORD_RESET_EXPIRE=60
PASSWORD_RESET_THROTTLE=60
EMAIL_VERIFICATION_EXPIRE=60

# Mail — set MAIL_MAILER=smtp and SMTP vars for production; defaults to console log
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=SEO Dashboard
# MAIL_HOST=
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
