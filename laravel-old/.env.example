APP_NAME=Laravel

# Optional: protect public/server-setup.php (browser-based migrate/seed). Use a long random string; delete the PHP file after use.
# DEPLOY_SETUP_TOKEN=

APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Production example (no path): https://rankradar.dominioninc.org
# Subdirectory example: https://example.com/myapp (then set RewriteBase in public/.htaccess)

# Comma-separated IPs, or * when HTTPS is offloaded (Apache proxy, Cloudflare, etc.).
# TRUSTED_PROXIES=*

# SPA origin(s) for CORS. FRONTEND_URL is merged into allowed origins automatically.
FRONTEND_URL=http://localhost:5173
# Comma-separated list. Browsers cannot use Access-Control-Allow-Origin: * with credentials.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_SUPPORTS_CREDENTIALS=false
# Local: regex-match private IPs so phones / other PCs on LAN work without listing every origin.
CORS_ALLOW_PRIVATE_NETWORK_ORIGINS=true
# Optional: preflight cache seconds (e.g. 86400).
# CORS_MAX_AGE=86400

# Vite `npm run dev` proxies /api and /sanctum here (avoids CORS while developing).
# Use **http://** — `php artisan serve` does not speak TLS on this port.
VITE_DEV_BACKEND_URL=http://127.0.0.1:8000

# Optional: full API origin in the browser (skip Vite proxy). Must be **http://** for artisan serve.
# VITE_API_URL=http://192.168.100.58:8004
#
# Dev UI on localhost but API on production — use **https** and allow localhost in server .env:
#   VITE_API_URL=https://rankradar.dominioninc.org
#   CORS_ALLOWED_ORIGINS=https://rankradar.dominioninc.org,http://localhost:5173,http://127.0.0.1:5173

# Sanctum: guards checked before Bearer token (empty = token-only API). Use `web` for cookie SPA + stateful domains.
SANCTUM_GUARD=

# OpenAPI / Swagger UI (darkaonline/l5-swagger). UI: {APP_URL}/api/documentation
# Regenerate JSON: php artisan l5-swagger:generate
# false = Swagger loads /docs + assets from the same host as the browser (needed for LAN IP when APP_URL is different).
L5_SWAGGER_USE_ABSOLUTE_PATH=false
L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_CONST_HOST="${APP_URL}"

SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=password
# Fix super_admin only showing old permissions (no terminal): {APP_URL}/sync-super-admin-permissions.php

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# MySQL (cPanel / shared hosting):
# - Create database + MySQL user, then "Add User To Database" and grant ALL PRIVILEGES.
# - SQLSTATE[HY000] [1045] Access denied = wrong DB_USERNAME / DB_PASSWORD / DB_HOST, or user not linked to DB (not a migration bug).
# - If localhost fails, try DB_HOST=127.0.0.1
# - Passwords with # " $ & : prefer no wrapping, or single quotes, so .env parses correctly.
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=your_cpanel_dbname
# DB_USERNAME=your_cpanel_dbuser
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail: use "log" for local, or SMTP (e.g. Ethereal https://ethereal.email for throwaway testing).
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
#
# Ethereal example (do not commit real passwords):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.ethereal.email
# MAIL_PORT=587
# MAIL_USERNAME=your-generated@ethereal.email
# MAIL_PASSWORD=your-generated-password
# MAIL_FROM_ADDRESS="${MAIL_USERNAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
