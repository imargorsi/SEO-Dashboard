# =============================================================================
# PROJECT ROOT .htaccess  (same folder as `artisan`, `composer.json`, `index.php`)
# =============================================================================
# If you still see "Index of ..." after uploading this file, the server is NOT
# reading .htaccess. Fix one of these on the host:
#   - Enable "AllowOverride All" (or at least FileInfo + Options) for this folder
#   - Enable mod_rewrite
#   - Or change the site "document root" / "web root" to the `public/` folder
#
# SUBDIRECTORY INSTALL (URL contains /rankradar/SeoDashboard/ etc.):
#   Uncomment RewriteBase below so it matches the URL path to THIS folder (no
#   domain), e.g. RewriteBase /rankradar/SeoDashboard
#
# If the site is at the domain root and this folder IS the document root, leave
# RewriteBase commented.
# =============================================================================

DirectoryIndex index.php index.html

<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # >>> Uncomment for subdirectory URL (edit path to match your hosting):
    # RewriteBase /rankradar/SeoDashboard

    RewriteRule ^(.*)$ public/$1 [L,QSA]
</IfModule>

<IfModule mod_negotiation.c>
    Options -Indexes
</IfModule>
